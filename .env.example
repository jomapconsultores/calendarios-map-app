# Copia este archivo a ".env" y rellena tus valores reales. NO subas .env a git.
# Variables que lee config/config.py.

# --- App ---
FLASK_ENV=production
SECRET_KEY=                      # firma de sesiones. Ej: openssl rand -hex 32
PORT=5000
HOST=0.0.0.0

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=                    # service_role (solo servidor)

# --- Google Calendar (OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# --- Microsoft To-Do (Azure AD app) ---
# Sin estas, el módulo Microsoft To-Do y la sync por cron quedan inactivos (degradan sin romper).
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback

# --- Cron de sincronización To-Do ⇄ Sistema ---
CRON_SECRET=

# --- Observabilidad (Sentry) — opcional; vacío = desactivado ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# --- Sincronización de navegadores (Avast ⇄ Brave) ---
# ACTIVA por defecto (no hace falta ponerla). Acceso blindado a un único admin
# dueño (OWNER_EMAIL) + rol admin. En la web funciona el flujo CSV de contraseñas;
# marcadores y lectura directa de perfiles sólo funcionan en la PC Windows local.
# Para DESACTIVARLA en un despliegue concreto, pon BROWSER_SYNC_ENABLED=0.
BROWSER_SYNC_ENABLED=1
BROWSER_SYNC_OWNER_EMAIL=jomapconsultores@gmail.com
# En el servidor Linux (VPS) el flujo CSV de contraseñas SÍ funciona (no necesita
# navegadores). Los marcadores y la lectura directa sólo funcionan en la PC local.
# Ruta de la bóveda cifrada (opcional; por defecto ~/.local/share/... en Linux):
# BROWSER_SYNC_DATA_DIR=/var/lib/calendarios-map/browser_sync
